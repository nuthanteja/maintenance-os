PMOS_LOG_LEVEL=INFO
PMOS_API_HOST=127.0.0.1
PMOS_API_PORT=8000

PMOS_PREDICTOR_ID=minirocket
PMOS_PREDICTOR_PATH=models/minirocket_pipeline.joblib

PMOS_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Real-time ingestor: synthetic (default — works out of the box)
#                     replay (replays a saved JSONL file)
#                     serial (reads from the actual sensor over UART)
PMOS_INGESTOR=synthetic
PMOS_REPLAY_PATH=data/samples/replay.jsonl
PMOS_REPLAY_REALTIME=true
PMOS_REPLAY_LOOP=true
PMOS_SERIAL_PORT=COM3
PMOS_SERIAL_BAUDRATE=921600
PMOS_DEFAULT_RPM=2700
PMOS_TRIPLET_MAX_AGE_S=1.0
